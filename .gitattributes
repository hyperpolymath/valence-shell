# SPDX-License-Identifier: MPL-2.0
# RSR-compliant .gitattributes

# ============
# Default
# ============
* text=auto eol=lf

# ============
# Binary Files
# ============
*.png binary
*.jpg binary
*.gif binary
*.pdf binary
*.woff2 binary
*.zip binary
*.gz binary
*.so binary
*.dylib binary
*.o binary

# ============
# Source Code
# ============

# Rust
*.rs text eol=lf diff=rust

# Elixir
*.ex text eol=lf diff=elixir
*.exs text eol=lf diff=elixir

# Julia
*.jl text eol=lf

# ReScript
*.res text eol=lf
*.resi text eol=lf

# Ada
*.ada text eol=lf diff=ada
*.adb text eol=lf diff=ada
*.ads text eol=lf diff=ada

# Haskell
*.hs text eol=lf

# Chapel
*.chpl text eol=lf

# Scheme
*.scm text eol=lf

# Nix
*.nix text eol=lf

# ============
# Documentation
# ============
*.md text eol=lf diff=markdown
*.adoc text eol=lf
*.txt text eol=lf

# ============
# Data/Config
# ============
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf

# ============
# Build/Config Files
# ============
.gitignore text eol=lf
.gitattributes text eol=lf
Containerfile text eol=lf
Justfile text eol=lf
Makefile text eol=lf

# ============
# Scripts
# ============
*.sh text eol=lf

# ============
# Lock Files (no diff)
# ============
Cargo.lock text eol=lf -diff
flake.lock text eol=lf -diff
