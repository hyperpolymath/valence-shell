# valence-shell - Editor Configuration
# https://editorconfig.org

root = true

# ============
# Default
# ============
[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

# ============
# Documentation (preserve trailing whitespace)
# ============
[*.md]
trim_trailing_whitespace = false

[*.adoc]
trim_trailing_whitespace = false

# ============
# Language-Specific: 4-space indent
# ============
[*.rs]
indent_size = 4

[*.zig]
indent_size = 4

[*.ada]
indent_size = 3

[*.adb]
indent_size = 3

[*.ads]
indent_size = 3

[Justfile]
indent_size = 4

[justfile]
indent_size = 4

# ============
# Language-Specific: 2-space indent
# ============
[*.ex]
indent_size = 2

[*.exs]
indent_size = 2

[*.hs]
indent_size = 2

[*.res]
indent_size = 2

[*.resi]
indent_size = 2

[*.ncl]
indent_size = 2

[*.rkt]
indent_size = 2

[*.scm]
indent_size = 2

[*.nix]
indent_size = 2
